{
  "name": "smartstudy-ai-monorepo",
  "private": true,
  "workspaces": [
    "frontend",
    "mobile",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=frontend",
    "dev:mobile": "npm run dev --workspace=mobile",
    "build:web": "npm run build --workspace=frontend",
    "install:all": "npm install"
  }
}
