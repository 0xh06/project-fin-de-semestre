# Port d'écoute interne du serveur HTTP C
PORT=8080

# Clé secrète pour signer les JWT (CHANGEZ CECI EN PRODUCTION !)
JWT_SECRET=super_secret_key_change_me_in_prod

# URLs publiques du frontend et du backend
FRONTEND_URL=https://app.smartstudy.ai
BACKEND_URL=https://api.smartstudy.ai
NEXT_PUBLIC_API_URL=https://api.smartstudy.ai

# OAuth GitHub
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# OAuth Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Emplacement de la base de données SQLite (doit être dans le volume persistant /data)
SMARTSTUDY_DB_PATH=/data/smartstudy.db

# Clés d'API pour les services IA
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=AIza...
MISTRAL_API_KEY=...
