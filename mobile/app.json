{
  "expo": {
    "name": "SmartStudy AI",
    "slug": "smartstudy-ai-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "smartstudy",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A1A"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.smartstudy.ai",
      "infoPlist": {
        "NSCameraUsageDescription": "SmartStudy utilise la caméra pour scanner vos documents et les convertir en flashcards.",
        "NSPhotoLibraryUsageDescription": "SmartStudy accède à vos photos pour importer des documents."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0A1A"
      },
      "package": "com.smartstudy.ai",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "VIBRATE",
        "RECEIVE_BOOT_COMPLETED",
        "SCHEDULE_EXACT_ALARM"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-camera",
      "expo-notifications",
      "expo-haptics",
      "expo-document-picker",
      "expo-secure-store",
      "expo-sqlite",
      [
        "expo-font",
        {
          "fonts": ["./assets/fonts/Inter-Variable.ttf"]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "smartstudy-ai-mobile"
      }
    }
  }
}
